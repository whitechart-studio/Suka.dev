{
  "name": "suka",
  "version": "0.0.0",
  "private": true,
  "description": "Realtime coordination infrastructure for AI coding agents.",
  "type": "module",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspace @suka/dashboard",
    "clean": "npm run clean --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc -b --pretty false && npm run typecheck --workspace @suka/dashboard"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}
